sirius:
  topology:
    num_gpus: 1
  memory:
    gpu:
      usage_limit_fraction: 0.95
      reservation_limit_fraction: 0.9
      downgrade_trigger_fraction: 1.0
      downgrade_stop_fraction: 0.7
    host:
      capacity_bytes: 8Gi                 # per-NUMA-node
      reservation_limit_fraction: 0.9
      downgrade_trigger_fraction: 0.8
      downgrade_stop_fraction: 0.7
      block_size: 1Mi
      pool_size: 128
      initial_number_pools: 4
  executor:
    pipeline:
      num_threads: 4
    duckdb_scan:
      num_threads: 4
    task_creator:
      num_threads: 2
    downgrade:
      num_threads: 4
      monitor_period_ms: 10
  operator_params:
    scan_task_batch_size: 512Mi
    default_scan_task_varchar_size: 256
    max_sort_partition_bytes: 0
    hash_partition_bytes: 512Mi
    concat_batch_bytes: 512Mi
    max_build_hash_table_bytes: 500Mi
